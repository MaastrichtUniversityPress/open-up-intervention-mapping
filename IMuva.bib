pmid = {27960609},
title = {{Using the Theory of Planned Behavior to predict HPV vaccination intentions of college men}},
url = {http://www.ncbi.nlm.nih.gov/pubmed/27960609 https://www.tandfonline.com/doi/full/10.1080/07448481.2016.1269771},
volume = {65},
year = {2017}
}
@article{DiAnnaKinder2016,
abstract = {INTRODUCTION
The purpose of this study was to explore reasons why parents may defer administration of the human papillomavirus (HPV) vaccine to their children. The literature suggests that parents choose to defer administration of this vaccine for several reasons. Data from this pilot study will contribute to our understanding of why parents defer administration of the vaccine. 

METHOD
This mixed-methods study took place in a pediatric practice. After a health care visit in which the vaccine was deferred, a survey was provided to the parent in a private room. The survey was confidential and anonymous. 

RESULTS
A total of 23 surveys were completed. Demographic data were reported. Data were analyzed for descriptive statistics and themes from open-ended questions. The majority of parents (75{\%}) deferred administration of the HPV vaccine because they believed it was too new or required further research. 

DISCUSSION
Nurse practitioners are in an excellent position to dispel myths and clarify information about HPV vaccination. The data are useful in communicating with parents and promoting best practices to facilitate good health in children.},
author = {{DiAnna Kinder}, Frances},
doi = {10.1016/J.PEDHC.2015.11.013},
file = {:C$\backslash$:/Users/Nicole Oei/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/DiAnna Kinder - 2016 - Parental Refusal of the Human Papillomavirus Vaccine.pdf:pdf},
issn = {0891-5245},
journal = {Journal of Pediatric Health Care},
month = {nov},
number = {6},
pages = {551--557},
publisher = {Mosby},
title = {{Parental Refusal of the Human Papillomavirus Vaccine}},
url = {https://www-sciencedirect-com.proxy.uba.uva.nl:2443/science/article/pii/S0891524515004265},
volume = {30},
year = {2016}
}
